{
  "permissions": {
    "allow": [
      "Bash(gh auth *)",
      "Bash(git config *)",
      "Bash(ssh -T git@github.com)",
      "PowerShell(gh auth status 2>&1)",
      "PowerShell(git config --global user.name)",
      "PowerShell(git config --global user.email)",
      "PowerShell(ssh -T git@github.com 2>&1)",
      "PowerShell($env:Path = [System.Environment]::GetEnvironmentVariable\\(\"Path\",\"Machine\"\\) + \";\" + [System.Environment]::GetEnvironmentVariable\\(\"Path\",\"User\"\\); gh auth status)"
    ]
  }
}
